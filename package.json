{
  "name": "ryota2357.com",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "check": "biome check './'",
    "check:write": "biome check --write './'",
    "textlint": "textlint './content/**/*.md'",
    "textlint:fix": "textlint --fix './content/**/*.md'",
    "linkcheck": "./scripts/linkcheck",
    "new-post": "./scripts/new-post",
    "postbuild": "./scripts/generate_simple_html_files",
    "vrt": "playwright test tests/vrt.spec.ts",
    "vrt:full": "FULL_VRT=1 playwright test tests/",
    "vrt:update": "playwright test tests/vrt.spec.ts --update-snapshots",
    "vrt:ui": "FULL_VRT=1 playwright test tests/ --ui"
  },
  "dependencies": {
    "@astrojs/partytown": "2.1.7",
    "@astrojs/rss": "4.0.18",
    "@napi-rs/canvas": "0.1.100",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.2.2",
    "dayjs": "1.11.20",
    "destyle.css": "4.0.1",
    "sass": "1.99.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "unified": "11.0.5",
    "unist-util-is": "6.0.1",
    "unist-util-visit": "5.1.0",
    "unknownutil": "3.18.1",
    "vfile": "6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "1.59.1",
    "@types/node": "24.12.2",
    "@types/unist": "3.0.3",
    "textlint": "15.5.4",
    "textlint-filter-rule-comments": "1.3.0",
    "textlint-rule-preset-ja-spacing": "2.4.3",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "unist-util-inspect": "8.1.0"
  }
