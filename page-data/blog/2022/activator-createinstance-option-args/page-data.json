=\"mtk1\"> </span><span class=\"mtk12\">x</span><span class=\"mtk1\"> = </span><span class=\"mtk7\">10</span><span class=\"mtk1\">) {</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk1\">        </span><span class=\"mtk4\">this</span><span class=\"mtk1\">.</span><span class=\"mtk12\">X</span><span class=\"mtk1\"> = </span><span class=\"mtk12\">x</span><span class=\"mtk1\">;</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk1\">    }</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk1\">}</span></span></span></code></pre>\n<p>次のようになってしまう。</p>\n<pre class=\"grvsc-container default-dark\" data-language=\"cs\" data-index=\"1\"><code class=\"grvsc-code\"><span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk3\">// これはエラーになってしまう</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk4\">var</span><span class=\"mtk1\"> </span><span class=\"mtk12\">i</span><span class=\"mtk1\"> = </span><span class=\"mtk12\">Activator</span><span class=\"mtk1\">.</span><span class=\"mtk11\">CreateInstance</span><span class=\"mtk1\">(</span><span class=\"mtk4\">typeof</span><span class=\"mtk1\">(</span><span class=\"mtk10\">Test</span><span class=\"mtk1\">));</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk3\">// OK</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk4\">var</span><span class=\"mtk1\"> </span><span class=\"mtk12\">i</span><span class=\"mtk1\"> = </span><span class=\"mtk12\">Activator</span><span class=\"mtk1\">.</span><span class=\"mtk11\">CreateInstance</span><span class=\"mtk1\">(</span><span class=\"mtk4\">typeof</span><span class=\"mtk1\">(</span><span class=\"mtk10\">Test</span><span class=\"mtk1\">), </span><span class=\"mtk7\">5</span><span class=\"mtk1\">);</span></span></span></code></pre>\n<p>オプション引数を考慮してほしい。</p>\n<h2 id=\"解決\" style=\"position:relative;\"><a href=\"#%E8%A7%A3%E6%B1%BA\" aria-label=\"解決 permalink\" class=\"anchor before\"><svg aria-hidden=\"true\" version=\"1.1\" viewBox=\"0 0 16 16\" height=\"16\" width=\"16\" style=\"vertical-align:baseline; fill: #57606a;\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>解決</h2>\n<p>次のオーバーロードを使う。</p>\n<pre class=\"grvsc-container default-dark\" data-language=\"cs\" data-index=\"2\"><code class=\"grvsc-code\"><span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk4\">public</span><span class=\"mtk1\"> </span><span class=\"mtk4\">static</span><span class=\"mtk1\"> </span><span class=\"mtk4\">object</span><span class=\"mtk1\">? </span><span class=\"mtk11\">CreateInstance</span><span class=\"mtk1\"> (</span><span class=\"mtk10\">Type</span><span class=\"mtk1\"> </span><span class=\"mtk12\">type</span><span class=\"mtk1\">, </span><span class=\"mtk10\">System</span><span class=\"mtk1\">.</span><span class=\"mtk10\">Reflection</span><span class=\"mtk1\">.</span><span class=\"mtk10\">BindingFlags</span><span class=\"mtk1\"> </span><span class=\"mtk12\">bindingAttr</span><span class=\"mtk1\">, </span><span class=\"mtk10\">System</span><span class=\"mtk1\">.</span><span class=\"mtk10\">Reflection</span><span class=\"mtk1\">.</span><span class=\"mtk10\">Binder</span><span class=\"mtk1\">? </span><span class=\"mtk12\">binder</span><span class=\"mtk1\">, object?[]? args, </span><span class=\"mtk10\">System</span><span class=\"mtk1\">.</span><span class=\"mtk10\">Globalization</span><span class=\"mtk1\">.</span><span class=\"mtk10\">CultureInfo</span><span class=\"mtk1\">? </span><span class=\"mtk12\">culture</span><span class=\"mtk1\">);</span></span></span></code></pre>\n<p><a href=\"https://learn.microsoft.com/en-us/dotnet/api/system.activator.createinstance?view=net-6.0#system-activator-createinstance(system-type-system-reflection-bindingflags-system-reflection-binder-system-object()-system-globalization-cultureinfo\">ドキュメント</a></p>\n<p>それぞれの引数はこんな感じにすれば期待通りになる。</p>\n<pre class=\"grvsc-container default-dark\" data-language=\"cs\" data-index=\"3\"><code class=\"grvsc-code\"><span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk4\">var</span><span class=\"mtk1\"> </span><span class=\"mtk12\">instance</span><span class=\"mtk1\"> = </span><span class=\"mtk12\">Activator</span><span class=\"mtk1\">.</span><span class=\"mtk11\">CreateInstance</span><span class=\"mtk1\">(</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk1\">    </span><span class=\"mtk12\">type</span><span class=\"mtk1\">: </span><span class=\"mtk4\">typeof</span><span class=\"mtk1\">(</span><span class=\"mtk10\">T</span><span class=\"mtk1\">),</span></span></span>\n<span class=\"grvsc-line\"><span class=\"grvsc-source\"><span class=\"mtk1\">    </span><span class=\"mtk12\">bindingAttr</span><span class=\"mtk1\">: </span><span class=\"mtk12\">BindingFlags</span><span class=\"mtk1\">.</span><span class=\"mtk12\">CreateInstance</span><span class=\"mtk1\"> | </span><span class=\"mtk12\">BindingFlags</span><span class=\"mtk1\">.</span><span class=\"mtk12\">Public</span><span class=\"mtk1\"> | </span><span class=\"mtk12\">BindingFlags</span><span class=\"mtk1\">.</span><span class=\"mtk12\">Instance</span><span class=\"mtk1\"> | </span><span class=\"mtk12\">BindingFlags</span><span class=\"mtk1\">.</span><span class=\"mtk12\">OptionalParamBinding</span><span class=\"mtk1\">,</span></span></span>\n<span class=\"grvsc-line\"><